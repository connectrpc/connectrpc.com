import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import Callout from "../components/home/Callout.astro";
import calloutStyles from "../components/home/Callout.module.css";
import Divider from "../components/home/Divider.astro";
import Examples from "../components/home/Examples.astro";
import Features from "../components/home/Features.astro";
import Guides from "../components/home/Guides.astro";
import Hero from "../components/home/Hero.astro";
import { callout } from "../components/home/text";
import styles from "./index.module.css";
---

<StarlightPage
  frontmatter={{ title: "Connect", template: "splash", tableOfContents: false }}
  headings={[]}
>
  <div class="not-content">
    <div class={styles.wrapper}>
      <Hero />
    </div>
    <div class={styles.gradient}>
      <Examples />
      <Features />
      <div class={styles.buttons}>
        <a href={callout.button.href} class={calloutStyles.button}>
          {callout.button.text}
        </a>
      </div>
      <div class="container">
        <Divider />
      </div>
      <Guides />
    </div>
    <div class={styles.footerBackground}>
      <div class={`container ${styles.moreInfo}`}>
        <Callout />
      </div>
    </div>
  </div>
</StarlightPage>

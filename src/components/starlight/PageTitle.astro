import Default from "@astrojs/starlight/components/PageTitle.astro";

// Splash-template pages render their own hero/title in the page body, so
// the auto-generated Starlight <h1> would just duplicate it. This covers
// the home page, demo, 404, and any future splash page without needing a
// hardcoded route list (the 404 page's entry id is the requested URL,
// so a route-id allowlist can't match it).
const template = Astro.locals.starlightRoute.entry.data.template;
const suppress = template === "splash";
---

{!suppress && <Default {...Astro.props}><slot /></Default>}

<style is:global>
  /* When PageTitle renders nothing, hide the otherwise-empty content panel
     Starlight wraps it in to avoid a stray top padding above the slot. */
  main > .content-panel:first-child:not(:has(h1)) {
    display: none;
  }
</style>


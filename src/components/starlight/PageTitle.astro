import Default from "@astrojs/starlight/components/PageTitle.astro";

// Pages that provide their own hero/heading and should suppress the
// auto-generated <h1>. Entry id is the route path with no leading slash.
const SUPPRESS_TITLE_IDS = new Set(["", "demo", "404"]);

const id = Astro.locals.starlightRoute.entry.id;
const suppress = SUPPRESS_TITLE_IDS.has(id);
---

{!suppress && <Default {...Astro.props}><slot /></Default>}

<style is:global>
  /* When PageTitle renders nothing, hide the otherwise-empty content panel
     Starlight wraps it in to avoid a stray top padding above the slot. */
  main > .content-panel:first-child:not(:has(h1)) {
    display: none;
  }
</style>


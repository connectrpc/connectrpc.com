import config from "virtual:starlight/user-config";
import LanguageSelect from "virtual:starlight/components/LanguageSelect";
import Search from "virtual:starlight/components/Search";
import SiteTitle from "virtual:starlight/components/SiteTitle";
import SocialIcons from "virtual:starlight/components/SocialIcons";
import ThemeSelect from "virtual:starlight/components/ThemeSelect";
import BufLogo from "./header-assets/buf.svg";

const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== "@astrojs/starlight/components/Search.astro";

// Splash pages have no Starlight sidebar drawer, so without our own
// disclosure the mobile header collapses to just the logo. Pages with a
// sidebar already get Starlight's <MobileMenuToggle /> in PageFrame.
const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <nav class="nav-links sl-hidden md:sl-flex" aria-label="Main">
    <a href="/docs/introduction/" class="nav-link">Docs</a>
    <a href="/demo/" class="nav-link">Demo</a>
  </nav>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex search-wrapper print:hidden">
      {shouldRenderSearch && <Search />}
    </div>
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
    <a href="https://buf.build" class="buf-button sl-hidden lg:sl-flex">
      <span>Created by</span>
      <span class="buf-logo"><BufLogo /></span>
    </a>
  </div>
  {
    !hasSidebar && (
      <details class="mobile-menu print:hidden">
        <summary class="mobile-menu-toggle" aria-label="Toggle menu">
          <svg
            class="mobile-menu-icon mobile-menu-icon-open"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg
            class="mobile-menu-icon mobile-menu-icon-close"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </summary>
        <div class="mobile-menu-panel">
          <nav class="mobile-menu-nav" aria-label="Mobile main">
            <a href="/docs/introduction/" class="mobile-menu-link">Docs</a>
            {config.social?.map((s) => (
              <a href={s.href} class="mobile-menu-link">
                {s.label}
              </a>
            ))}
            <a href="/demo/" class="mobile-menu-link">Demo</a>
          </nav>
          {shouldRenderSearch && (
            <div class="mobile-menu-search">
              <Search />
            </div>
          )}
          <div class="mobile-menu-controls">
            <ThemeSelect />
          </div>
          <a href="https://buf.build" class="mobile-menu-buf-button">
            <span>Created by</span>
            <span class="buf-logo"><BufLogo /></span>
          </a>
        </div>
      </details>
    )
  }
</div>

<script is:inline>
  // Lock body scroll while a full-screen mobile menu drawer is open.
  document.querySelectorAll("details.mobile-menu").forEach((d) => {
    d.addEventListener("toggle", () => {
      document.documentElement.classList.toggle("mobile-menu-open", d.open);
    });
  });
</script>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .nav-links {
      gap: 1.5rem;
      align-items: center;
    }

    .nav-link {
      color: var(--sl-color-white);
      text-decoration: none;
      text-transform: uppercase;
      font-family: var(--buf-mono-font);
      font-size: 1rem;
      letter-spacing: 0.08em;
      padding: 0.5rem 0.25rem;
      white-space: nowrap;
    }
    .nav-link:hover {
      color: var(--sl-color-text-accent);
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }
    .social-icons::after {
      content: "";
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }


    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__sidebar-width: max(
          0rem,
          var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x)
        );
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) -
                var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) -
                var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        display: grid;
        grid-template-columns:
          /* 1: site title — at least the sidebar+gutter width. */
          minmax(
            calc(
              var(--__sidebar-width) +
                max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))
            ),
            auto
          )
          /* 2: flexible center column containing the centered nav links. */
          1fr
          /* 3: right items: search + social + theme + language. */
          auto;
        align-content: center;
      }
      .nav-links {
        justify-self: center;
      }
    }
  }

  /* "Created by Buf" pill — far-right header affordance, separate from the
   * social-icon group. Outside @layer starlight.core so Starlight's own
   * styles don't override it. */
  .buf-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    background-color: white;
    border: 1px solid #d0e3e8;
    border-radius: 2px;
    font-size: 12px;
    text-decoration: none;
    color: #090a3a;
  }
  .buf-button span {
    font-family: var(--buf-mono-font);
    text-transform: uppercase;
    letter-spacing: 0.075rem;
  }
  .buf-button:hover {
    cursor: pointer;
    text-decoration: none;
    background-color: #f8f8ff;
    border-color: #cbcbf3;
  }
  .buf-logo {
    display: inline-flex;
    align-items: center;
  }
  .buf-logo :global(svg) {
    height: 23px;
    width: auto;
    display: block;
  }

  :global(:root[data-theme="dark"]) .buf-button {
    background-color: transparent;
    color: var(--sl-color-text);
  }
  :global(:root[data-theme="dark"]) .buf-button:hover {
    background-color: var(--buf-grey-01);
  }

  /* Full-screen mobile drawer for splash pages (home / demo / 404), which
   * have no Starlight sidebar toggle. Hidden at the same md breakpoint
   * where the inline nav-links + right-group become visible. */
  .mobile-menu {
    display: block;
  }
  @media (min-width: 50rem) {
    .mobile-menu {
      display: none;
    }
  }
  .mobile-menu-toggle {
    position: relative;
    z-index: calc(var(--sl-z-index-menu, 10) + 1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--sl-color-white);
    background: transparent;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    cursor: pointer;
    list-style: none;
  }
  .mobile-menu-toggle::-webkit-details-marker {
    display: none;
  }
  .mobile-menu-icon-close {
    display: none;
  }
  .mobile-menu[open] .mobile-menu-icon-open {
    display: none;
  }
  .mobile-menu[open] .mobile-menu-icon-close {
    display: block;
  }
  .mobile-menu-panel {
    position: fixed;
    inset: 0;
    z-index: var(--sl-z-index-menu, 10);
    padding: calc(var(--sl-nav-height) + 1rem) 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background-color: var(--sl-color-bg-nav);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .mobile-menu-nav {
    display: flex;
    flex-direction: column;
  }
  .mobile-menu-link {
    display: block;
    padding: 0.75rem 0;
    color: var(--sl-color-white);
    font-family: var(--buf-mono-font);
    font-size: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border-block-end: 1px solid var(--sl-color-hairline-shade);
  }
  .mobile-menu-link:hover {
    color: var(--sl-color-text-accent);
  }
  /* Search widget inside the drawer: keyboard shortcuts (⌘K) are
   * meaningless on touch devices, hide the hint pill. */
  .mobile-menu-search :global(kbd) {
    display: none;
  }
  .mobile-menu-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-block-start: 0.5rem;
  }
  /* Created-by-Buf pill at the bottom of the drawer. Mirrors the desktop
   * .buf-button visual, with margin-block-start: auto pushing it to the
   * bottom of the column. */
  .mobile-menu-buf-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-block-start: auto;
    padding: 0.75rem 1rem;
    background-color: white;
    border: 1px solid #d0e3e8;
    border-radius: 2px;
    color: #090a3a;
    text-decoration: none;
    font-size: 0.875rem;
  }
  .mobile-menu-buf-button span {
    font-family: var(--buf-mono-font);
    text-transform: uppercase;
    letter-spacing: 0.075rem;
  }
  .mobile-menu-buf-button .buf-logo :global(svg) {
    height: 23px;
    width: auto;
  }
  :global(:root[data-theme="dark"]) .mobile-menu-buf-button {
    background-color: transparent;
    color: var(--sl-color-text);
  }

  /* Body scroll lock when the drawer is open (toggled by inline script). */
  :global(html.mobile-menu-open) {
    overflow: hidden;
  }
</style>

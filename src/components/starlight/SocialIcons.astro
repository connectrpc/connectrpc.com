import Default from "@astrojs/starlight/components/SocialIcons.astro";
---

<Default><slot /></Default>

<style>
  /* Override Starlight's default social icon color (--sl-color-text-accent)
   * so GitHub/Slack icons match the site title: dark in light mode,
   * white in dark mode. The default's hover state already uses
   * --sl-color-white, which still works after this change. */
  :global(.social-icons > a) {
    color: var(--sl-color-white);
  }
</style>

// The full-width marketing footer is rendered in PageFrame.astro so it spans
// the page below the sidebar and TOC columns. Here we only decide whether
// Starlight's default per-page footer (pagination, edit link) should render.
// On splash pages there is no pagination or edit link to show, so suppress it.
import Default from "@astrojs/starlight/components/Footer.astro";

// Splash pages have no pagination or edit-link to render, and the 404
// page's entry id is the requested URL, so we key off the template
// (matches the same suppression in PageTitle.astro).
const template = Astro.locals.starlightRoute.entry.data.template;
const suppress = template === "splash";
---

{!suppress && <Default {...Astro.props}><slot /></Default>}

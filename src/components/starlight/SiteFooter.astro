import CncfSandbox from "./footer-assets/cncf-sandbox-horizontal-black.svg";

const year = new Date().getFullYear();
const copyright = `Copyright © ${year !== 2022 ? "2022–" : ""}${year} The Connect Authors`;

const legalLinks = [
  { label: "Terms", href: "https://www.linuxfoundation.org/terms" },
  { label: "Privacy", href: "https://www.linuxfoundation.org/privacy" },
  {
    label: "Trademarks",
    href: "https://www.linuxfoundation.org/trademark-usage",
  },
  {
    label: "License",
    href: "https://github.com/connectrpc/connectrpc.com/blob/main/LICENSE",
  },
];
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="legal-group">
      {
        legalLinks.map((l) => (
          <a class="legal-link" href={l.href}>
            {l.label}
          </a>
        ))
      }
    </div>

    <div class="copyright">
      <div set:html={copyright} />
      <span>We are a Cloud Native Computing Foundation sandbox project</span>
      <CncfSandbox width={200} class="cncf-logo" />
    </div>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .site-footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 2.5rem;
    padding-bottom: 5rem;
    border-top: 1px solid var(--sl-color-hairline);
    width: 100%;
    position: relative;
  }
  /* Splash pages have no .page max-width constraint, so the footer would
   * otherwise stretch to the full viewport. Match the global `.container`
   * width (90rem) so the footer aligns with the home page content and the
   * outer frame of docs pages, keeping the chrome consistent as the user
   * navigates across page templates. */
  :global(:root:not([data-has-sidebar])) .site-footer-inner {
    max-width: 90rem;
  }
  .legal-group {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    padding: 32px 20px;
    gap: 1.8rem;
  }
  .legal-link {
    text-transform: uppercase;
    color: #93b4be;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    font-family: var(--buf-mono-font);
    text-decoration: none;
    padding-bottom: 0.125rem;
    background-image: linear-gradient(0deg, currentColor 1px, transparent 0);
    background-repeat: no-repeat;
    background-size: 0 100%;
    transition:
      background-size 0.4s ease-in-out,
      opacity 0.4s ease-in-out;
  }
  .legal-link:hover {
    background-size: 100% 100%;
    text-decoration: none;
  }
  .copyright {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 0.875rem;
    color: #acb3b6;
    font-family: var(--buf-sans-font);
    text-align: center;
  }
  .cncf-logo {
    padding-top: 0.3rem;
    opacity: 0.2;
  }
  :global(:root[data-theme="dark"]) .cncf-logo {
    fill: white;
    stroke: white;
  }
  :global(:root[data-theme="light"]) .cncf-logo {
    fill: black;
    stroke: black;
  }

  /* Wide viewports: lay out legal links on the left and copyright/CNCF on
     the right via a 2-column grid so each column's height contributes to
     the footer's total height (preserving the 5rem bottom padding below
     the taller column, like the original Docusaurus footer). */
  @media (min-width: 1200px) {
    .site-footer-inner {
      display: grid;
      grid-template-columns: auto auto;
      justify-content: space-between;
      align-items: start;
    }
    .legal-group {
      padding: 0;
    }
    .copyright {
      align-items: end;
      text-align: right;
    }
  }
</style>

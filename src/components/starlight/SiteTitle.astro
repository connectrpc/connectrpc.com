// Inline the Connect logo so it paints with the rest of the header. Starlight's
// default SiteTitle renders an <img> pointing at the hashed SVG, which fires a
// second network round-trip after the HTML lands and shows a brief flicker on
// cold loads.
import ConnectLogo from "../../../public/img/logos/simple-connect.svg";

const { siteTitleHref, siteTitle } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex">
  <ConnectLogo class="logo" aria-hidden="true" />
  <span translate="no">{siteTitle}</span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: var(--sl-nav-gap);
    font-size: var(--sl-text-h4);
    font-weight: 600;
    color: var(--sl-color-white);
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }
  .logo {
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    width: auto;
    flex-shrink: 0;
  }
</style>

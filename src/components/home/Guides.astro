import Divider from "./Divider.astro";
import styles from "./Guides.module.css";
import { guides } from "./text";
---

<div class={styles.guideBackground} id="guides">
  <div class="container">
    {
      guides.map((row) => (
        <div class={styles.guideList}>
          {row.map((guide) => (
            <div class={styles.guideCard}>
              <div class={styles.titleAndIcon} style="flex-grow: 1">
                <div class={styles.logoContainer}>
                  {guide.logos.map((logo) => (
                    <img alt={guide.title} src={logo} class={styles.logo} />
                  ))}
                </div>
                <div>
                  <p class={styles.title}>{guide.title}</p>
                  {guide.description && (
                    <p class={styles.description}>{guide.description}</p>
                  )}
                </div>
              </div>
              <Divider style="width: 100%; margin-bottom: 1.5rem; margin-top: 1.5rem" />
              <a class={styles.goto} href={guide.href}>
                <span class={styles.gotoText}>Go to guide </span>
                <span class={styles.gotoArrow}>&#8594;</span>
              </a>
            </div>
          ))}
        </div>
      ))
    }
  </div>
</div>

{
  "name": "connect-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check:types": "astro check && tsc --noEmit",
    "format": "npm run format:src && npm run format:md",
    "format:src": "biome format --write .",
    "format:md": "rumdl fmt .",
    "lint": "npm run lint:src && npm run lint:md",
    "lint:src": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:md": "rumdl check .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "license-header": "license-header",
    "ci": "npm run build && npm run check:fix && npm run lint:md && npm run check:types && npm run license-header",
    "publish": "npm install && npm run lint && npm run check:types && npm run build"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@astrojs/starlight": "^0.39.2",
    "@buf/connectrpc_eliza.bufbuild_es": "^2.2.2-20230913231627-233fca715f49.2",
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/work-sans": "^5.2.8",
    "@react-hookz/web": "^25.2.0",
    "astro": "^6.3.3",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-custom-heading-id": "^2.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@biomejs/biome": "2.4.13",
    "@bufbuild/license-header": "^0.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rumdl": "^0.1.92",
    "typescript": "^5.9.3"
  },
  "licenseHeader": {
